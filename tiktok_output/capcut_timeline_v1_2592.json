    "captions": [
      {
        "text": "A sudden storm swallowed two hundred sailors in one night.",
        "position": {
          "start": 0,
          "end": 3.1
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Calm waters reflected a pale, fading autumn sun.",
        "position": {
          "start": 3.1,
          "end": 6.2
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Then the sky bruised purple and the wind screamed.",
        "position": {
          "start": 6.2,
          "end": 9.48
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Waves climbed higher than lighthouses, swallowing wooden decks whole.",
        "position": {
          "start": 9.48,
          "end": 13.78
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Freezing spray turned rigging into heavy, jagged glass.",
        "position": {
          "start": 13.78,
          "end": 17.38
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Captains fought blind as compasses spun in the dark.",
        "position": {
          "start": 17.38,
          "end": 20.68
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "By dawn, only splintered timber drifted across silent shores.",
        "position": {
          "start": 20.68,
          "end": 24.7
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
