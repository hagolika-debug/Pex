          "start": 12.61,
          "end": 14.37
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000"
        }
      },
      {
        "text": "Another top finisher sprinted barefoot while being chased by wild dogs.",
        "position": {
