    "captions": [
      {
        "text": "In 1986, a silent lake in Cameroon killed nearly two thousand people overnight.",
        "position": {
          "start": 0,
          "end": 5.04
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "No earthquake. No explosion. Just a sudden, invisible cloud rolling down the valley.",
        "position": {
          "start": 5.6,
          "end": 7.38
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Deep beneath the water, volcanic carbon dioxide had been building for decades.",
        "position": {
          "start": 11.44,
          "end": 15.48
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "A landslide finally cracked the seal, releasing a suffocating wave heavier than air.",
        "position": {
          "start": 16.1,
          "end": 20.98
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "It moved at highway speeds, extinguishing every flame and breath in its path.",
        "position": {
          "start": 21.48,
          "end": 25.88
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Survivors woke to absolute silence, finding entire villages untouched but completely lifeless.",
        "position": {
          "start": 26.52,
          "end": 32.18
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
        "text": "Scientists now monitor the lake, pumping gas to prevent history from repeating itself.",
        "position": {
          "start": 33.08,
          "end": 37.58
        },
        "style": {
          "font": "System Bold",
          "size": 48,
          "color": "#FFFFFF",
          "stroke": "#000000",
          "stroke_width": 3
        }
      },
      {
